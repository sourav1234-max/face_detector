# Copy to .env for local use, or set these in the Vercel project settings.

# Required for persistent storage (Firebase)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Keep quotes and escape newlines as \n when pasting into Vercel
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Public site URL (used for Google OAuth redirect). Example:
# PUBLIC_BASE_URL=https://your-app.vercel.app
PUBLIC_BASE_URL=

# Optional override for Google OAuth callback URI. Use if PUBLIC_BASE_URL is not enough.
# GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/google/callback
GOOGLE_REDIRECT_URI=

# Optional overrides
ADMIN_PASSWORD=admin123
SESSION_SECRET=change-me-to-a-long-random-string
# 0 = never auto-delete photos (recommended)
PHOTO_RETENTION_HOURS=0

# Optional Google Drive (photos stored here when connected; metadata stays in Firestore)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: pre-set refresh token instead of OAuth connect flow
GOOGLE_REFRESH_TOKEN=
# Optional: fixed folder ID for images; otherwise the app creates FaceMatch_Photos
GOOGLE_DRIVE_FOLDER_ID=

PORT=3000
NODE_ENV=development
